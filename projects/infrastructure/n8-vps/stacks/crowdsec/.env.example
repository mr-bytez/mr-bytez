# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  CrowdSec — Environment-Variablen                                          ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║  Kopieren: cp .env.example .env                                            ║
# ║  Dann Werte eintragen und .env NICHT committen!                            ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# --- Central API ---
# Enrollment-Key von https://app.crowdsec.net/ → Security Engines → Add
CROWDSEC_ENROLL_KEY=

# --- Bouncer API-Keys ---
# Nach Enrollment generieren: docker exec mrbz-crowdsec cscli bouncers add traefik-bouncer
# Dieser Key wird in Traefik .env eingetragen (CROWDSEC_BOUNCER_API_KEY)
# CROWDSEC_TRAEFIK_BOUNCER_KEY=

# Nach Enrollment generieren: docker exec mrbz-crowdsec cscli bouncers add firewall-bouncer
# Dieser Key wird in /etc/crowdsec/bouncers/crowdsec-firewall-bouncer.yaml eingetragen
# CROWDSEC_FIREWALL_BOUNCER_KEY=
