# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Traefik — Environment-Variablen                                            ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║  WICHTIG: Diese Datei nach .env kopieren und Werte eintragen\!               ║
# ║  .env ist gitignored — Secrets NIEMALS committen\!                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Hetzner DNS API-Token (fuer ACME DNS-01 Challenge)
# Token aus Secrets-Archiv: mr-bytez-dns-management.secret
# Berechtigungen: DNS Zone Read + Write
HETZNER_API_TOKEN=<aus-secrets-eintragen>

# CrowdSec Traefik Bouncer API-Key
# Generieren: docker exec mrbz-crowdsec cscli bouncers add traefik-bouncer
# Secret-Archiv: crowdsec_traefik_bouncer_api_key.secret
CROWDSEC_BOUNCER_API_KEY=<aus-secrets-eintragen>
